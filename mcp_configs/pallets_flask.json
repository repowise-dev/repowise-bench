{
  "mcpServers": {
    "repowise": {
      "command": "${REPOWISE_BENCH}/.venv/bin/python3",
      "args": [
        "-m",
        "repowise.cli.main",
        "mcp",
        "${REPOWISE_BENCH}/repos/pallets/flask",
        "--transport",
        "stdio"
      ],
      "env": {
        "PYTHONPATH": "${REPOWISE_ROOT}/packages/cli/src:${REPOWISE_ROOT}/packages/core/src:${REPOWISE_ROOT}/packages/server/src",
        "PYTHONIOENCODING": "utf-8",
        "PYTHONUTF8": "1"
      }
    }
  }
}
